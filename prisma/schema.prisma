// Biometrics testing model
model BiometricsTest {
  id                   String   @id @default(cuid())
  playerId             String
  player               Player   @relation(fields: [playerId], references: [id])
  testType             String   // 20m_sprint, vertical_leap, pro_agility
  durationSeconds      Float
  ageGroup             String   // U8, U13, U17, Senior
  rawScore             String
  percentile           Int
  tier                 String   // Elite (Class A), Competitive (Class B), Developmental
  scoutNarrative       String
  recommendedPositions String[]
  suggestedDrills      String[]
  date                 DateTime @default(now())
  notes                String?
  
  @@index([playerId])
  @@index([date])
}