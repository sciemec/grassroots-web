generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// World Cup tournament container
model Tournament {
  id        String   @id @default(cuid())
  name      String
  country   String?
  year      Int?
  status    String   @default("scheduled")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  matches WorldCupMatch[]
}

// World Cup match records (populated from API)
model WorldCupMatch {
  id           String    @id @default(cuid())
  matchDate    DateTime?
  homeTeam     String?
  awayTeam     String?
  homeScore    Int       @default(0)
  awayScore    Int       @default(0)
  status       String    @default("scheduled")
  stage        String?
  groupName    String?
  tournamentId String?

  tournament Tournament? @relation(fields: [tournamentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Tracks which matches have been synced to player stats
model WorldCupMatchSync {
  id       String   @id @default(cuid())
  matchId  String   @unique
  syncedAt DateTime @default(now())
}

// Aggregated player statistics across all World Cup matches
model WorldCupPlayerStats {
  id               String   @id @default(cuid())
  playerId         String   @unique
  playerName       String
  country          String
  position         String
  shirtNumber      Int      @default(0)
  matchesPlayed    Int      @default(0)
  minutesPlayed    Int      @default(0)
  goals            Int      @default(0)
  assists          Int      @default(0)
  shots            Int      @default(0)
  shotsOnTarget    Int      @default(0)
  passAccuracy     Float    @default(0)
  passesCompleted  Int      @default(0)
  passesAttempted  Int      @default(0)
  tackles          Int      @default(0)
  interceptions    Int      @default(0)
  clearances       Int      @default(0)
  saves            Int      @default(0)
  cleanSheets      Int      @default(0)
  yellowCards      Int      @default(0)
  redCards         Int      @default(0)
  avgRating        Float    @default(0)
  performanceScore Float    @default(0)
  lastUpdated      DateTime @default(now())
  updatedAt        DateTime @updatedAt
}
