    "topic": "Losing a Marker",
    "steps": [
      {
        "step_number": 1,
        "instruction": "Make the marker lose sight of the ball and/or our position."
      },
      {
        "step_number": 2,
        "instruction": "Use feints of two supports or more."
      },
      {
        "step_number": 3,
        "instruction": "Create space by moving initially in the opposite direction to the area in which we want to receive the ball."
